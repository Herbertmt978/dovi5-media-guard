# Scanner safety and state tuning
MIN_FILE_AGE_SECONDS=300
FIND_TIMEOUT_SECONDS=600
FINGERPRINT_TIMEOUT_SECONDS=30
MEDIAINFO_TIMEOUT_SECONDS=300
FFPROBE_TIMEOUT_SECONDS=60
FFMPEG_TIMEOUT_SECONDS=120
VALIDATOR_MEMORY_LIMIT_KIB=2097152
# Validation-derived deletions are all-or-nothing above this per-run limit.
# Positively identified Dolby Vision Profile 5 files are not limited by it.
MAX_VALIDATION_DELETIONS_PER_RUN=1
STATE_COMPACT_EVERY=5000
STATE_COMPACT_INTERVAL_SECONDS=86400

# Media mount and library roots
MEDIA_MOUNTPOINT=/mnt/media
PLEX_TV_DIR=/mnt/media/PlexTV
PLEX_TVHD_DIR=/mnt/media/PlexTVHD
PLEX_FILMS_DIR=/mnt/media/PlexFilms
PLEX_FILMSHD_DIR=/mnt/media/PlexFilmsHD

# Durable recovery state (systemd creates the parent StateDirectory).
SERVARR_OUTBOX_DB=/var/lib/dovi5-frigate-ops/servarr-outbox.sqlite3
SERVARR_API_TIMEOUT_SECONDS=30
SERVARR_SUPERSEDED_RETENTION_SECONDS=2592000

# Per-library Servarr targets.
# Keep API keys only in the deployed /home/frigate/dovi5-frigate-ops.env file.
SONARR_TV_URL=http://sonarr.example.invalid:8989
SONARR_TV_API_KEY=
SONARR_TVHD_URL=http://sonarr-hd.example.invalid:8989
SONARR_TVHD_API_KEY=
RADARR_FILMS_URL=http://radarr.example.invalid:7878
RADARR_FILMS_API_KEY=
RADARR_FILMSHD_URL=http://radarr-hd.example.invalid:7878
RADARR_FILMSHD_API_KEY=
